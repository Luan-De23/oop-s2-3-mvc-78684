@model IEnumerable<VgcCollege.Library.AttendaceRecord>

@{
    ViewData["Title"] = "Attendance Details";
}

<div class="container mt-4">
    <h2>Attendance Details - Week @ViewBag.Week</h2>
    <hr />

    <table class="table table-striped border">
        <thead class="table-light">
        <tr>
            <th>Student Name</th>
            <th>Status</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CourseEnrolment.StudentProfile.Name</td>
                <td>
                    @if (item.Present == VgcCollege.Library.AttendaceStatus.Present)
                    {
                        <span class="badge bg-success">Present</span>
                    }
                    else if (item.Present == VgcCollege.Library.AttendaceStatus.Absent)
                    {
                        <span class="badge bg-danger">Absent</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Late</span>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>

    <div class="mt-3">
        <a href="javascript:history.back()" class="btn btn-secondary">Back to History</a>
    </div>
</div>