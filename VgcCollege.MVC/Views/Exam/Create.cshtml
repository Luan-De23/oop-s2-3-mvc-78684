@model VgcCollege.Library.Exam

@{
    ViewData["Title"] = "Create Exam";
}

<h1>Create Exam</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="form-group mb-3">
                <label asp-for="Title" class="control-label fw-bold"></label>
                <input asp-for="Title" class="form-control" placeholder="Ex: Final Math Exam" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CourseId" class="control-label fw-bold">Course</label>
                <select asp-for="CourseId" class="form-select" asp-items="ViewBag.CourseId">
                    <option value="">-- Select Course --</option>
                </select>
                <span asp-validation-for="CourseId" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="ExamDate" class="control-label fw-bold"></label>
                        <input asp-for="ExamDate" class="form-control" type="date" />
                        <span asp-validation-for="ExamDate" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="MaxScore" class="control-label fw-bold"></label>
                        <input asp-for="MaxScore" class="form-control" type="number" value="100" />
                        <span asp-validation-for="MaxScore" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-group mt-4">
                <button type="submit" class="btn btn-primary">Create Exam</button>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>