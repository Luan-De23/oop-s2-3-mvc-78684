@model IEnumerable<VgcCollege.Library.ExamResult>

@{
    ViewData["Title"] = "Exam Results";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-clipboard-check me-2"></i>Exam Results</h1>
</div>

<table class="table table-hover shadow-sm bg-white rounded">
    <thead class="table-dark">
    <tr>
        <th>Student</th>
        <th>Exam</th>
        <th>Score</th>
        <th>Grade</th>
        <th>Faculty</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model) {
        <tr>
            <td>@item.StudentProfile?.Name</td>
            <td>@item.Exam?.Title</td>
            <td><strong>@item.Score</strong></td>
            <td><span class="badge bg-info text-dark">@item.Grade</span></td>
            <td>@item.FacultyProfile?.Name</td>
            <td>
                <div class="btn-group">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
        
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Details</a>
        
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </div>
            </td>
        </tr>
    }
    </tbody>
</table>