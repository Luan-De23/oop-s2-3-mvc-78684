@model VgcCollege.Library.ExamResult

@{
    ViewData["Title"] = "Add Grade";
}

<h1>Add Grade</h1>
<h4>Exam: @ViewBag.ExamTitle</h4>
<hr />

<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            @* Campo oculto para o ID do Exame *@
            <input type="hidden" asp-for="ExamId" value="@ViewBag.ExamId" />

            <div class="form-group mb-3">
                <label asp-for="StudentProfileId" class="control-label">Student</label>
                @* Mudamos asp-items para "StudentList" *@
                <select asp-for="StudentProfileId" class="form-control" asp-items="ViewBag.StudentList">
                    <option value="">-- Select Student --</option>
                </select>
                <span asp-validation-for="StudentProfileId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Score" class="control-label"></label>
                <input asp-for="Score" class="form-control" type="number" />
                <span asp-validation-for="Score" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Grade" class="control-label"></label>
                <input asp-for="Grade" class="form-control" placeholder="Ex: A, B, Excellent..." />
                <span asp-validation-for="Grade" class="text-danger"></span>
            </div>

            <div class="form-group mt-4">
                <input type="submit" value="Save Result" class="btn btn-primary" />
                <a asp-controller="Exam" asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>