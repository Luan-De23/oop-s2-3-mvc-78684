@model VgcCollege.Library.AssignmentResult

@{
    ViewData["Title"] = "Enter Grade";
}

<h1>Enter Grade</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="form-group mb-3">
                <label asp-for="AssigmentId" class="control-label">Assignment</label>
                <select asp-for="AssigmentId" class="form-control" asp-items="ViewBag.AssigmentId">
                    <option value="">-- Select Assignment --</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="StudentProfileId" class="control-label">Student</label>
                <select asp-for="StudentProfileId" class="form-control" asp-items="ViewBag.StudentProfileId">
                    <option value="">-- Select Student --</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Score" class="control-label"></label>
                <input asp-for="Score" class="form-control" type="number" />
                <span asp-validation-for="Score" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="FeedBack" class="control-label"></label>
                <textarea asp-for="FeedBack" class="form-control" rows="3"></textarea>
                <span asp-validation-for="FeedBack" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Save Grade" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back</a>
            </div>
        </form>
    </div>
</div>