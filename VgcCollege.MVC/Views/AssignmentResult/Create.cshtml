@model VgcCollege.Library.AssignmentResult

@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Create</h1>

<h4>AssignmentResult</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Score" class="control-label"></label>
                <input asp-for="Score" class="form-control" />
                <span asp-validation-for="Score" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FeedBack" class="control-label"></label>
                <input asp-for="FeedBack" class="form-control" />
                <span asp-validation-for="FeedBack" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AssigmentId" class="control-label"></label>
                <select asp-for="AssigmentId" class ="form-control" asp-items="ViewBag.AssigmentId"></select>
            </div>
            <div class="form-group">
                <label asp-for="StudentProfileId" class="control-label"></label>
                <select asp-for="StudentProfileId" class ="form-control" asp-items="ViewBag.StudentProfileId"></select>
            </div>
            <div class="form-group">
                <label asp-for="FacultyProfileId" class="control-label"></label>
                <select asp-for="FacultyProfileId" class ="form-control" asp-items="ViewBag.FacultyProfileId"></select>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
