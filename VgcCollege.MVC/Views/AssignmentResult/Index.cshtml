@model IEnumerable<VgcCollege.Library.AssignmentResult>

@{
    ViewData["Title"] = "Grades & Results";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Grades & Results</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Enter New Grade</a>
</p>

<table class="table table-hover border">
    <thead class="table-light">
    <tr>
        <th>Student</th>
        <th>Assignment</th>
        <th>Score</th>
        <th>Feedback</th>
        <th>Graded By</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model) {
        <tr>
            <td>@Html.DisplayFor(modelItem => item.StudentProfile.Email)</td>
            <td>@Html.DisplayFor(modelItem => item.Assigment.Title)</td>
            <td><strong>@item.Score</strong> / @item.Assigment?.MaxScore</td>
            <td>@Html.DisplayFor(modelItem => item.FeedBack)</td>
            <td>@Html.DisplayFor(modelItem => item.FacultyProfile.Email)</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>