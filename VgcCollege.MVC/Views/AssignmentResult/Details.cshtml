@model VgcCollege.Library.AssignmentResult

@{
    ViewData["Title"] = "Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Details</h1>

<div>
    <h4>AssignmentResult</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Student</dt>
        <dd class="col-sm-10">@Model.StudentProfile?.Email</dd>

        <dt class="col-sm-2">Assignment</dt>
        <dd class="col-sm-10">@Model.Assigment?.Title</dd>

        <dt class="col-sm-2">Score</dt>
        <dd class="col-sm-10">@Model.Score</dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
