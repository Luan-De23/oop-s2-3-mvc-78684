@model VgcCollege.Library.AssignmentResult

@{
    ViewData["Title"] = "Edit Grade";
}

<h1>Edit Grade</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="FacultyProfileId" />

            <div class="form-group mb-3">
                <label asp-for="AssigmentId" class="control-label">Assignment</label>
                <select asp-for="AssigmentId" class="form-control" asp-items="ViewBag.AssigmentId"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="StudentProfileId" class="control-label">Student</label>
                <select asp-for="StudentProfileId" class="form-control" asp-items="ViewBag.StudentProfileId"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Score" class="control-label"></label>
                <input asp-for="Score" class="form-control" />
                <span asp-validation-for="Score" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="FeedBack" class="control-label"></label>
                <textarea asp-for="FeedBack" class="form-control" rows="3"></textarea>
                <span asp-validation-for="FeedBack" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Update Grade" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>