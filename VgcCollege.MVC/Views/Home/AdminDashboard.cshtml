@model AdminDashboardViewModel
<div class="container mt-4">
    <h2 class="mb-4">Admin Dashboard</h2>
    
    <div class="row text-center">
        <div class="col-md-3">
            <div class="card bg-primary text-white shadow-sm mb-4">
                <div class="card-body">
                    <h5>Students</h5>
                    <h2 class="display-4">@Model.TotalStudents</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white shadow-sm mb-4">
                <div class="card-body">
                    <h5>Faculty</h5>
                    <h2 class="display-4">@Model.TotalFaculty</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="card p-3 mt-4">
        <h4>Quick Actions</h4>
        <div class="d-flex gap-2">
            <a asp-controller="Student" asp-action="Create" class="btn btn-outline-primary">Create Student</a>
            <a asp-controller="Course" asp-action="Create" class="btn btn-outline-success">Create Course</a>
            <a asp-controller="CourseEnrolment" asp-action="Index" class="btn btn-outline-info">Manage Enrolments</a>
        </div>
    </div>
</div>