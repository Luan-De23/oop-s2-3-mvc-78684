@model StudentDashboardViewModel

@{
    ViewData["Title"] = "Student Dashboard";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-mortarboard me-2"></i>Welcome, @User.Identity.Name!</h2>
        <span class="badge bg-dark p-2">Student Portal</span>
    </div>

    <div class="row">
        <div class="col-md-7">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-book me-2"></i>My Enrolments</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Course</th>
                                    <th>Branch</th>
                                    <th class="text-center">Attendance</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.MyEnrolments)
                                {
                                    <tr>
                                        <td><strong>@item.Course?.Name</strong></td>
                                        <td><i class="bi bi-geo-alt me-1"></i>@item.Course?.Branch</td>
                                        <td class="text-center" style="width: 150px;">
                                            <div class="progress" style="height: 18px;" title="Attendance">
                                                <div class="progress-bar bg-success" role="progressbar" style="width: 85%;" aria-valuenow="85" aria-valuemin="0" aria-valuemax="100">85%</div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-journal-text me-2"></i>Examination Results</h5>
                    <small class="text-muted">Official Exams</small>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Exam Title</th>
                                    <th>Course</th>
                                    <th class="text-center">Status / Grade</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RecentExams == null || !Model.RecentExams.Any())
                                {
                                    <tr><td colspan="3" class="text-center py-3 text-muted">No exams recorded.</td></tr>
                                }
                                else
                                {
                                    @foreach (var examRes in Model.RecentExams)
                                    {
                                        <tr>
                                            <td>@examRes.Exam?.Title</td>
                                            <td><small>@examRes.Exam?.Course?.Name</small></td>
                                            <td class="text-center">
                                                @if (examRes.Exam != null && examRes.Exam.ResultReleased)
                                                {
                                                    <span class="badge bg-success fs-6">@examRes.Score / @examRes.Exam.MaxScore</span>
                                                    <div class="small fw-bold text-uppercase mt-1">@examRes.Grade</div>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning text-dark">
                                                        <i class="bi bi-lock-fill me-1"></i> Pending Release
                                                    </span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card shadow-sm mb-4 border-0">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-star me-2"></i>Recent Assignments</h5>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @if (!Model.RecentResults.Any())
                        {
                            <li class="list-group-item text-muted text-center py-4">No assignment grades yet.</li>
                        }
                        @foreach (var result in Model.RecentResults)
                        {
                            <li class="list-group-item py-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-0 fw-bold">@result.Assigment?.Title</h6>
                                        <small class="text-muted"><i class="bi bi-layers me-1"></i>@result.Assigment?.Course?.Name</small>
                                    </div>
                                    <div class="text-end">
                                        <div class="badge bg-light text-primary border border-primary fs-6">
                                            @result.Score / @result.Assigment?.MaxScore
                                        </div>
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(result.FeedBack))
                                {
                                    <div class="mt-2 p-2 bg-light rounded small text-secondary">
                                        <i class="bi bi-chat-left-text me-1"></i> @result.FeedBack
                                    </div>
                                }
                            </li>
                        }
                    </ul>
                </div>
                <div class="card-footer bg-white text-center">
                    <a asp-controller="Student" asp-action="MyGrades" class="btn btn-sm btn-link">View Full Report Card</a>
                </div>
            </div>
        </div>
    </div>
</div>